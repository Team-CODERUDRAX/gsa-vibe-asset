# ═══════════════════════════════════════════
# .env — Gemini Builders Community
# Copy this to .env and fill in your values.
# NEVER commit .env to Git.
# ═══════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development

# (Optional) Database — if you swap JSON files for a real DB later
# DATABASE_URL=mongodb://localhost:27017/gbc
# Or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/gbc

# (Optional) Email notifications for new signups
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword

# (Optional) Admin secret for protected routes
# ADMIN_SECRET=change_this_to_something_strong
